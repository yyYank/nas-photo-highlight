# NAS mount paths (set these after mounting your NAS)
NAS_PHOTO_PATH=/Volumes/photo          # Mac: SMB mount path to photos folder
NAS_OUTPUT_PATH=/Volumes/highlights    # Mac: SMB mount path to output folder

# Processing settings
GROUP_BY=date                          # date | folder
IMAGES_PER_HIGHLIGHT=25                # number of best shots to pick per event
SECONDS_PER_IMAGE=3                    # display duration per image in the movie
MIN_IMAGES_TO_GENERATE=5              # skip generation if fewer images in group

# BGM (optional)
BGM_PATH=                              # absolute path to .mp3 file, leave empty to disable

# Web server
PORT=3000

# Schedule (cron syntax) — runs daily at 2am
CRON_SCHEDULE=0 2 * * *
