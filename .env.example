# NAS mount paths (set these after mounting your NAS)
NAS_PHOTO_PATH=/Volumes/photo          # Mac: SMB mount path to photos folder
NAS_META_OUTPUT_PATH=/Volumes/highlights # Mac: SMB mount path to meta info output folder
NAS_OUTPUT_PATH=/Volumes/highlights    # Mac: SMB mount path to movie output folder

# Processing settings
GROUP_BY=date                          # date | folder
IMAGES_PER_HIGHLIGHT=25                # number of best shots to pick per event
SECONDS_PER_IMAGE=3                    # display duration per image in the movie
MIN_IMAGES_TO_GENERATE=5              # skip generation if fewer images in group

# BGM (optional)
BGM_PATH=                              # absolute path to .mp3 file, leave empty to disable

# Notification (optional)
NOTIFY_PROVIDER=gmail                  # webhook | gmail
BASE_URL=                              # e.g. http://192.168.1.10:8888 for highlight links in notifications
NOTIFY_WEBHOOK_URL=                    # webhook URL for sending the latest generation result
GMAIL_FROM=                            # sender address shown in Gmail notification
GMAIL_TO=                              # destination address for Gmail notification
GMAIL_USER=                            # Gmail account used for SMTP auth
GMAIL_APP_PASSWORD=                    # Gmail app password for SMTP auth

# Web server
PORT=8888

# NAS web deploy
NAS_DEPLOY_HOST=                       # e.g. admin@nas.local
NAS_DEPLOY_DIR=                        # remote directory to place docker-compose.yml and nginx.conf
NAS_DEPLOY_META_PATH=                  # NAS-local path for meta output bind mount
NAS_DEPLOY_MEDIA_PATH=                 # NAS-local path for PhotoLibrary bind mount, {yyyy}/{mm} is allowed
NAS_DEPLOY_PORT=8888                   # published port on the NAS
NAS_DEPLOY_DOCKER_BIN=docker           # e.g. /usr/local/bin/docker when docker is not on non-interactive PATH

# Schedule (cron syntax) — runs daily at 2am
CRON_SCHEDULE=0 2 * * *
