{
  "name": "synology-photo-highlight",
  "version": "0.1.0",
  "description": "Auto-generate highlight movies from NAS photos",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outdir dist",
    "score:test": "bun src/scorer/imageScore.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "fluent-ffmpeg": "^2.1.3",
    "node-cron": "^3.0.3",
    "sharp": "^0.33.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "bun-types": "^1.3.11",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {}
}
