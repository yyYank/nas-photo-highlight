{
  "name": "nas-photo-highlight",
  "version": "0.1.0",
  "description": "Auto-generate highlight movies from NAS photos",
  "type": "module",
  "scripts": {
    "generate": "bun src/index.ts --run-now",
    "generate:force": "bun src/index.ts --run-now --force",
    "notify": "bun src/index.ts --notify",
    "schedule": "bun src/index.ts",
    "deploy:nas": "bun src/deploy.ts",
    "deploy:nas:dry-run": "bun src/deploy.ts --dry-run",
    "cli:highlight": "bun src/cli/run-highlight.ts",
    "cli:evaluate": "bun src/cli/evaluate-highlight.ts",
    "dev": "bun --watch src/index.ts",
    "score": "bun src/scorer/imageScore.ts",
    "build": "bun build src/index.ts --outdir dist",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "fluent-ffmpeg": "^2.1.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "sharp": "^0.33.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "bun-types": "^1.3.11",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {}
}
